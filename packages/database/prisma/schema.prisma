generator client {
  provider = "prisma-client-js"
  output   = "./../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Locker {
  lockerId  Int          @id @map("locker_id")
  weight    Int?
  auditLogs AuditLog[]
  users     UserLocker[]

  @@map("locker")
}

model User {
  uinPhilsys String       @id @map("uin_philsys") @db.VarChar
  name       String       @db.VarChar(100)
  userRole   role         @map("user_role")
  audit_log  AuditLog[]
  lockers    UserLocker[]

  @@map("user")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model UserLocker {
  lockerId Int    @map("locker_id")
  userId   String @map("user_id") @db.VarChar
  ul_id    Int    @id @default(autoincrement())
  locker   Locker @relation(fields: [lockerId], references: [lockerId], onDelete: NoAction, onUpdate: NoAction)
  user     User   @relation(fields: [userId], references: [uinPhilsys], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_locker")
}

model AuditLog {
  logId     BigInt        @id @default(autoincrement()) @map("log_id")
  createdAt DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  lockerId  Int?          @map("locker_id")
  logMsg    String?       @map("log_msg") @db.VarChar(100)
  sysType   sys_log_type? @map("sys_type")
  user_id   String?       @db.VarChar
  locker    Locker?       @relation(fields: [lockerId], references: [lockerId], onDelete: NoAction, onUpdate: NoAction)
  user      User?         @relation(fields: [user_id], references: [uinPhilsys], onDelete: NoAction, onUpdate: NoAction)

  @@map("audit_log")
}

enum role {
  Admin
  User
}

enum sys_log_type {
  Registering
  Unregister
  Tampered
  Added_user    @map("Added user")
  Locker_Opened
  Revoke_Access
  Locker_Closed
  Denied_Access
}
